{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://breachlogic.io/schemas/puzzle/v1",
  "title": "BreachLogic Puzzle Schema v1.0",
  "description": "Defines the structure of a single BreachLogic System Map puzzle",
  "type": "object",
  "required": ["id","version","meta","map","rules","tokens","solution","pedagogy"],
  "properties": {
    "id":      { "type": "string", "pattern": "^BL-[A-Z0-9]{4}-[0-9]{4}$", "description": "Unique puzzle ID e.g. BL-CLUD-0001" },
    "version": { "type": "string", "description": "Schema version, must match schema $id version" },
    "meta": {
      "type": "object",
      "required": ["title","tier","domain","season","estimated_minutes","author","status"],
      "properties": {
        "title":              { "type": "string" },
        "tier":               { "type": "integer", "minimum": 1, "maximum": 5, "description": "1=Scout, 2=Analyst, 3=Auditor, 4=Red-Teamer, 5=Grandmaster" },
        "tier_label":         { "type": "string", "enum": ["Scout","Analyst","Auditor","Red-Teamer","Grandmaster"] },
        "domain":             { "type": "string", "enum": ["Cloud IAM","AI Agents","Financial Controls","Supply Chain","Incident Response","Compliance GRC","Network","Identity"] },
        "season":             { "type": "integer", "description": "Season number this puzzle belongs to" },
        "estimated_minutes":  { "type": "integer" },
        "author":             { "type": "string" },
        "status":             { "type": "string", "enum": ["draft","review","approved","published","retired"] },
        "tags":               { "type": "array", "items": { "type": "string" } },
        "framework_refs":     { "type": "array", "items": { "type": "string" }, "description": "NIST, ISO etc control refs e.g. NIST-PR.AC-4" }
      }
    },
    "narrative": {
      "type": "object",
      "required": ["scenario","intel_brief"],
      "properties": {
        "scenario":    { "type": "string", "description": "2-3 sentence scene-setting for the player" },
        "intel_brief": { "type": "string", "description": "Flavour text shown before puzzle loads — generated by AI pipeline" },
        "world":       { "type": "string", "description": "Fictional org/system name — never a real company" }
      }
    },
    "map": {
      "type": "object",
      "description": "The node graph that renders on the visual canvas",
      "required": ["nodes","edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id","label","type","position"],
            "properties": {
              "id":       { "type": "string" },
              "label":    { "type": "string", "description": "Display label on canvas" },
              "sublabel": { "type": "string", "description": "Secondary info e.g. cost, privilege level" },
              "type":     { "type": "string", "enum": ["actor","gate","process","target","system"] },
              "position": {
                "type": "object",
                "required": ["x","y"],
                "properties": { "x": {"type":"number"}, "y": {"type":"number"} }
              },
              "locked":      { "type": "boolean", "default": false, "description": "True = player cannot place token here" },
              "token_slot":  { "type": "boolean", "default": true,  "description": "False = decorative node, not interactive" },
              "privilege":   { "type": "string", "enum": ["user","system","admin","none"] }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from","to"],
            "properties": {
              "from":       { "type": "string" },
              "to":         { "type": "string" },
              "label":      { "type": "string" },
              "type":       { "type": "string", "enum": ["flow","condition","trigger","bypass"] },
              "blocked_by": { "type": "string", "description": "Gate node ID that blocks traversal of this edge" }
            }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "description": "The If/Then policy statements shown in the Rule Set panel",
      "items": {
        "type": "object",
        "required": ["id","gate_id","label","condition","effect"],
        "properties": {
          "id":        { "type": "string" },
          "gate_id":   { "type": "string", "description": "Corresponds to a gate node ID in map.nodes" },
          "label":     { "type": "string", "description": "Short name e.g. Identity Gate" },
          "condition": { "type": "string", "description": "The IF clause" },
          "effect":    { "type": "string", "description": "The THEN clause" },
          "seam_hint": { "type": "string", "description": "Internal only — not shown to player. Describes the exploitable gap." }
        }
      }
    },
    "tokens": {
      "type": "object",
      "required": ["count","labels"],
      "properties": {
        "count":  { "type": "integer", "minimum": 1, "maximum": 5 },
        "labels": { "type": "array", "items": { "type": "string" }, "description": "Display names for each Action Token slot" }
      }
    },
    "objective": {
      "type": "object",
      "required": ["description","target_node","unauthorized_outcome"],
      "properties": {
        "description":         { "type": "string", "description": "One-sentence player goal shown in the Objective panel" },
        "target_node":         { "type": "string", "description": "Node ID of the unauthorized target" },
        "unauthorized_outcome":{ "type": "string", "description": "What achieving the target represents in plain language" }
      }
    },
    "solution": {
      "type": "object",
      "required": ["steps","seam_type","seam_description"],
      "properties": {
        "steps": {
          "type": "array",
          "description": "Ordered list of token placements that constitute the valid solution",
          "items": {
            "type": "object",
            "required": ["step","node_id","action","mechanism"],
            "properties": {
              "step":      { "type": "integer" },
              "node_id":   { "type": "string" },
              "action":    { "type": "string", "description": "What the player places or does at this node" },
              "mechanism": { "type": "string", "description": "Why this works — the logical chain" }
            }
          }
        },
        "seam_type": {
          "type": "string",
          "enum": ["missing-clause","policy-contradiction","privilege-escalation","race-condition","ai-logic-chain","scope-confusion","delegation-chain"],
          "description": "Canonical seam category — shown on share card after solving"
        },
        "seam_description": { "type": "string", "description": "The teaching moment — 2-3 sentences explaining the inter-policy gap" },
        "alternate_paths":  { "type": "array", "items": { "type": "string" }, "description": "Other valid logical paths the engine will also accept" }
      }
    },
    "pedagogy": {
      "type": "object",
      "required": ["aha_moment","ctem_principle","hint_sequence"],
      "properties": {
        "aha_moment":    { "type": "string", "description": "The insight the player should walk away with" },
        "ctem_principle":{ "type": "string", "description": "Which CTEM pillar this puzzle exercises" },
        "hint_sequence": {
          "type": "array",
          "description": "Progressive Socratic hints — passed to AI hint engine, never revealed verbatim",
          "items": {
            "type": "object",
            "required": ["level","prompt"],
            "properties": {
              "level":  { "type": "integer", "minimum": 1, "maximum": 3 },
              "prompt": { "type": "string", "description": "Question Claude uses to guide reasoning without giving the answer" }
            }
          }
        },
        "framework_mapping": {
          "type": "array",
          "items": { "type": "string" },
          "description": "NIST/ISO control IDs this puzzle exercises"
        }
      }
    }
  }
}
